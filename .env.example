# Usado pelo docker-compose.yml para provisionar todos os serviços

# Postgres
POSTGRES_USER=fiscalflow
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=fiscalflow
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Backend
BACKEND_PORT=3001
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d
AUTH_THROTTLE_LIMIT=5
CORS_ORIGIN=http://localhost:8080
# Chave mestra (32 bytes em base64) para criptografar o Certificado A1 em repouso.
# Gere a sua com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CERTIFICATE_ENCRYPTION_KEY=5IzY8fkExE+3qUkuFXNkRUrwH29d7UeluhGFw1VC7iA=

# Frontend
FRONTEND_PORT=3000
# true somente quando o tráfego chegar via HTTPS na borda (TLS termina antes do nginx)
COOKIE_SECURE=false

# Nginx (porta pública exposta ao host)
NGINX_PORT=8080
