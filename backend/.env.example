# App
NODE_ENV=development
PORT=3001
API_GLOBAL_PREFIX=api

# Database
DATABASE_URL=postgresql://fiscalflow:fiscalflow@localhost:5432/fiscalflow?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate limit das rotas de autenticação (requisições por minuto por IP)
AUTH_THROTTLE_LIMIT=5

# Chave mestra (32 bytes em base64) para criptografar o Certificado A1 em repouso.
# Esta é só um valor de exemplo válido para rodar localmente — gere a sua para produção com:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CERTIFICATE_ENCRYPTION_KEY=5IzY8fkExE+3qUkuFXNkRUrwH29d7UeluhGFw1VC7iA=
